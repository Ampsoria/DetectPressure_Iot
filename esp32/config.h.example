/*
 * =============================================================================
 *  config.h — การตั้งค่าสำหรับระบบตรวจจับแรงกด (Pressure Monitoring System)
 * =============================================================================
 *  แก้ไขค่าเหล่านี้ก่อนอัปโหลดไปยัง ESP32
 *  1. คัดลอกไฟล์นี้เป็น config.h
 *     cp config.h.example config.h
 *  2. ใส่ค่าจริงลงไป
 * =============================================================================
 */

#ifndef CONFIG_H
#define CONFIG_H

// =============================================================================
//  ข้อมูล WiFi
// =============================================================================
#define WIFI_SSID          "YOUR_WIFI_SSID"
#define WIFI_PASSWORD      "YOUR_WIFI_PASSWORD"

// =============================================================================
//  Firebase Realtime Database
// =============================================================================
// หาค่าเหล่านี้ได้ที่ Firebase Console → Project Settings
#define FIREBASE_HOST      "YOUR_PROJECT.firebaseio.com"   // ไม่ต้องใส่ "https://"
#define FIREBASE_API_KEY   "YOUR_FIREBASE_API_KEY"
#define FIREBASE_USER_EMAIL    "YOUR_FIREBASE_AUTH_EMAIL"         // อีเมล Firebase Auth
#define FIREBASE_USER_PASSWORD "YOUR_FIREBASE_AUTH_PASSWORD"      // รหัสผ่าน Firebase Auth

// =============================================================================
//  Telegram Bot
// =============================================================================
// สร้างบอทผ่าน @BotFather บน Telegram แล้วคัดลอก Token มาใส่
#define TELEGRAM_BOT_TOKEN "YOUR_TELEGRAM_BOT_TOKEN"
// ส่ง /start ไปที่ @userinfobot เพื่อดู Chat ID
#define TELEGRAM_CHAT_ID   "YOUR_TELEGRAM_CHAT_ID"

// =============================================================================
//  ข้อมูลอุปกรณ์
// =============================================================================
#define DEVICE_ID          "esp32_node_01"
#define DEVICE_LOCATION    "เตียง A, ห้อง 101"

// =============================================================================
//  กำหนดขาพิน (Pin Assignments)
// =============================================================================
#define ANALOG_PIN         34    // GPIO34 — อ่านค่า Analog จาก Conversion Module
#define DIGITAL_PIN        35    // GPIO35 — Digital Output จาก Conversion Module (สำรอง)
#define WIFI_LED_PIN       18    // GPIO18 — หลอด LED สีฟ้า แสดงสถานะ WiFi
#define PRESS_LED_PIN      19    // GPIO19 — หลอด LED แสดงสถานะการกด (มีแรงกด = ติด)
#define LED_STATUS_PIN     2     // On-board LED (สำรอง)

// =============================================================================
//  ADC & Calibration (โหมด Inverted — ค่า ADC ต่ำ = มีแรงกด)
// =============================================================================
#define ADC_RESOLUTION     4095  // 12-bit ADC (0–4095)
#define SENSOR_MAX_KG      5.0   // ความจุสูงสุดของ RFP-602 (กก.)
#define VOLTAGE_REF        3.3   // แรงดันอ้างอิง

// *** Inverted Logic: ค่า ADC สูง = ไม่มีแรงกด, ค่า ADC ต่ำ = มีแรงกด ***
// ADC เมื่อไม่มีแรงกด (sensor ว่าง) — ปรับตามจริงที่วัดได้
#define ADC_NO_LOAD        4095
// ADC เมื่อกดเต็มพิกัด (5 kg) — ปรับตามจริงที่วัดได้
#define ADC_FULL_LOAD      0

// Threshold สำหรับตรวจจับว่า "มีแรงกดหรือไม่" (Inverted: ต่ำกว่านี้ = กด)
#define ADC_PRESS_THRESHOLD 2000

// =============================================================================
//  Moving Average Filter (ตัวกรองค่าเฉลี่ยเคลื่อนที่)
// =============================================================================
#define MOVING_AVG_SAMPLES 20    // จำนวนตัวอย่างสำหรับการ Smooth ค่า

// =============================================================================
//  เกณฑ์แรงกด & ตัวตั้งเวลาแจ้งเตือน
// =============================================================================
// น้ำหนักขั้นต่ำ (กก.) ที่ถือว่า "ตรวจพบแรงกด"
#define PRESSURE_THRESHOLD_KG       0.5

// ถ้ากดค้างเกินกี่วินาที → ส่งแจ้งเตือน (ปรับได้)
// *** โหมด DEMO: 10 วินาที | โหมดจริง: เปลี่ยนเป็น 1800 (30 นาที) ***
#define CONTINUOUS_PRESSURE_SECONDS 10

// น้ำหนักที่ผิดปกติ (กก.) — แจ้งเตือนทันทีถ้าเกินค่านี้
#define ABNORMAL_PRESSURE_KG        4.5

// ระยะเวลาขั้นต่ำระหว่างการแจ้งเตือน Telegram (วินาที)
// *** โหมด DEMO: 15 วินาที | โหมดจริง: เปลี่ยนเป็น 300 (5 นาที) ***
#define ALERT_COOLDOWN_SECONDS      15    // 15 วินาที (Demo)

// =============================================================================
//  ช่วงเวลาส่งข้อมูล
// =============================================================================
// ส่งข้อมูลไป Firebase ทุกๆ กี่มิลลิวินาที
#define DATA_PUSH_INTERVAL_MS       2000  // ทุก 2 วินาที

// ส่ง Heartbeat (ยืนยันว่าออนไลน์) ทุกๆ กี่มิลลิวินาที
#define HEARTBEAT_INTERVAL_MS       10000 // ทุก 10 วินาที

// อ่านค่า Sensor ทุกๆ กี่มิลลิวินาที
#define SENSOR_READ_INTERVAL_MS     100   // ทุก 100 ms (10 Hz)

// =============================================================================
//  History Log
// =============================================================================
// จำนวน Entry สูงสุดที่เก็บใน Firebase ต่ออุปกรณ์
#define MAX_HISTORY_ENTRIES         1000

#endif // CONFIG_H
