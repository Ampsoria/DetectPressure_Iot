{
  "rules": {
    "sensors": {
      "$deviceId": {
        "current": {
          ".read": true,
          ".write": "auth != null"
        },
        "history": {
          ".read": true,
          ".write": "auth != null",
          ".indexOn": ["timestamp"]
        },
        "status": {
          ".read": true,
          ".write": "auth != null"
        },
        "alerts": {
          ".read": true,
          ".write": "auth != null",
          ".indexOn": ["timestamp"]
        }
      }
    }
  }
}
